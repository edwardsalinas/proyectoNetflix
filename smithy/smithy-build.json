{
    "version": "1.0",
    "sources": [
        "models"
    ],
    "maven": {
        "dependencies": [
            "software.amazon.smithy:smithy-model:1.50.0",
            "software.amazon.smithy:smithy-aws-traits:1.50.0",
            "software.amazon.smithy:smithy-validation-model:1.50.0",
            "software.amazon.smithy:smithy-linters:1.50.0",
            "software.amazon.smithy.typescript:smithy-typescript-codegen:0.22.0",
            "software.amazon.smithy:smithy-aws-apigateway-traits:1.50.0",
            "com.disneystreaming.alloy:alloy-core:0.3.38"
        ],
        "repositories": [
            {
                "url": "https://repo.maven.apache.org/maven2/"
            }
        ]
    },
    "projections": {
        "source": {
            "plugins": {
                "typescript-client-codegen": {
                    "service": "com.netflix.api#NetflixService",
                    "package": "@netflix-project/netflix-client",
                    "packageVersion": "1.0.0"
                }
            }
        }
    }
}
